// Color Picker Component
function ColorPicker({ 
  label, 
  value, 
  onChange 
}: { 
  label: string
  value: string
  onChange: (value: string) => void
}) {
  return (
    <div className="flex items-center gap-3">
      <label className="block text-sm font-medium text-gray-700 min-w-[120px]">{label}</label>
      <div className="flex items-center gap-2">
        <input
          type="color"
          value={value || '#000000'}
          onChange={(e) => onChange(e.target.value)}
          className="w-10 h-10 rounded cursor-pointer border border-gray-300"
        />
        <input
          type="text"
          value={value || ''}
          onChange={(e) => onChange(e.target.value)}
          className="w-24 px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-purple-500"
          placeholder="#000000"
        />
      </div>
    </div>
  )
}

// Section Colors Editor Component
function SectionColorsEditor({ 
  colors, 
  onChange,
  sectionType
}: { 
  colors: any
  onChange: (colors: any) => void
  sectionType: string
}) {
  const defaultColors: Record<string, any> = {
    hero: {
      backgroundColor: '#ffffff',
      titleColor: '#1f2937',
      subtitleColor: '#4b5563',
      buttonColor: '#7c3aed',
      buttonTextColor: '#ffffff'
    },
    promotionalBanner: {
      backgroundColor: '#fef3c7',
      titleColor: '#92400e',
      textColor: '#b45309',
      highlightColor: '#d97706'
    },
    trackRecord: {
      backgroundColor: '#f3f4f6',
      titleColor: '#1f2937',
      textColor: '#4b5563',
      accentColor: '#7c3aed'
    },
    subjectsOffered: {
      backgroundColor: '#ffffff',
      titleColor: '#1f2937',
      textColor: '#4b5563',
      buttonColor: '#2563eb'
    },
    methodology: {
      backgroundColor: '#f0fdf4',
      titleColor: '#166534',
      textColor: '#15803d',
      cardBackgroundColor: '#ffffff',
      buttonColor: '#16a34a'
    },
    testimonials: {
      backgroundColor: '#faf5ff',
      titleColor: '#1f2937',
      subtitleColor: '#6b7280',
      buttonColor: '#7c3aed'
    },
    whyChooseUs: {
      backgroundColor: '#ffffff',
      titleColor: '#1f2937',
      textColor: '#4b5563',
      cardBackgroundColor: '#f9fafb',
      iconColor: '#7c3aed'
    }
  }

  const handleChange = (key: string, value: string) => {
    onChange({
      ...(colors || {}),
      [key]: value
    })
  }

  const resetToDefaults = () => {
    if (defaultColors[sectionType]) {
      onChange(defaultColors[sectionType])
    }
  }

  const colorFields = defaultColors[sectionType] || {}
  const colorKeys = Object.keys(colorFields)

  return (
    <div className="bg-purple-50 rounded-lg p-4 border border-purple-200">
      <div className="flex items-center justify-between mb-4">
        <h4 className="text-sm font-semibold text-purple-800 flex items-center gap-2">
          <Palette className="w-4 h-4" />
          Section Colors
        </h4>
        <button
          onClick={resetToDefaults}
          className="text-xs text-purple-600 hover:text-purple-800 underline"
        >
          Reset to Defaults
        </button>
      </div>
      
      <div className="grid grid-cols-2 gap-4">
        {colorKeys.map((key) => (
          <ColorPicker
            key={key}
            label={key.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase())}
            value={colors?.[key] || colorFields[key]}
            onChange={(value) => handleChange(key, value)}
          />
        ))}
      </div>
    </div>
  )
}

